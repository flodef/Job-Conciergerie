# Get those from your database provider (Vercel)
DATABASE_URL=""

# Get those from your email provider
SMTP_HOST=""
SMTP_PORT=""
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM_EMAIL=""

# Get those from your IPFS provider
IPFS_JWT=""
NEXT_PUBLIC_GATEWAY_DOMAIN=""
NEXT_PUBLIC_IPFS_API_URL=""
NEXT_PUBLIC_IPFS_PUBLIC_URL=""

# Set the base URL of your application (e.g. https://job-conciergerie.fr) 
# or leave empty for development
NEXT_PUBLIC_APP_URL=""

# Maximum number of devices a single user can connect (defaults to 5)
NEXT_PUBLIC_MAX_DEVICES="5"

# Random secret used to authenticate the email retry cron job.
# Generate with: openssl rand -hex 32
CRON_SECRET=""

# Optional: email address that receives alerts when an email is permanently abandoned.
# Defaults to contact@job-conciergerie.fr
ADMIN_ALERT_EMAIL=""
