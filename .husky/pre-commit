echo "📦 Checking version before push..."
bun run version:bump

# Add the updated package.json to the commit
git add package.json

if git diff --cached --name-only | grep -E '\.(ts(x)?|js(x)?)$'; 
then 
    echo "Running tests..."
    # bun run test || exit 1
    # Run unit tests only (skip integration tests that need full Next.js context)
    # bun test app/__tests__/storage.test.ts app/__tests__/storage.utils.test.ts app/__tests__/id.utils.test.ts
    echo "Running build..."
    bun run build || exit 1
else 
    echo "Running lint..."
    bun run lint
fi

echo "✅ Version updated and staged for commit"